{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(git init)",
      "Bash(npm test:*)",
      "Bash(npm ls:*)",
      "Bash(npm install:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__figma-remote-mcp__get_design_context",
      "mcp__figma-remote-mcp__whoami",
      "mcp__figma-remote-mcp__get_screenshot",
      "mcp__figma-remote-mcp__get_variable_defs",
      "Bash(git commit:*)",
      "mcp__firebase__firebase_login",
      "mcp__firebase__firebase_create_project",
      "mcp__firebase__firebase_get_environment",
      "mcp__firebase__firebase_list_projects",
      "mcp__firebase__firebase_update_environment",
      "mcp__firebase__firebase_create_app",
      "mcp__firebase__firebase_read_resources",
      "Bash(npx firebase-tools:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq . > tool-use.json"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read ti_file_path; [[ \"$ti_file_path\" =~ \\.tsx?$ ]] && npx prettier --write \"$ti_file_path\"; }"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"HOOK_EXECUTED\" >> /tmp/hook_test.log"
          }
        ]
      }
    ]
  }
}
