{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(git init)",
      "Bash(npm test:*)",
      "Bash(npm ls:*)",
      "Bash(npm install:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq . > tool-use.json"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read ti_file_path; [[ \"$ti_file_path\" =~ \\.tsx?$ ]] && npx prettier --write \"$ti_file_path\"; }"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"HOOK_EXECUTED\" >> /tmp/hook_test.log"
          }
        ]
      }
    ]
  }
}
