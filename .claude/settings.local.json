{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls:*)",
      "Bash(git init)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"hello\""
          },
          {
            "type": "command",
            "command": "jq . > tool-use.json"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"HOOK_EXECUTED\" >> /tmp/hook_test.log"
          }
        ]
      }
    ]
  }
}
